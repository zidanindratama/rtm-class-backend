NODE_ENV=local
PORT=5000

# Local app -> Docker DB/Redis (published ports on host)
DATABASE_URL=postgresql://rtm_class_user:rtm_class_password@localhost:5433/rtm_class?schema=public
REDIS_URL=redis://localhost:6380

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Mail (optional for local; set EMAIL_DISABLE_SEND=true to bypass SMTP)
OTP_EXPIRES_MINUTES=15
EMAIL_USER=
EMAIL_APP_PASSWORD=
EMAIL_FROM=
EMAIL_PROVIDER=smtp
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_REQUIRE_TLS=true
EMAIL_TLS_REJECT_UNAUTHORIZED=false
EMAIL_STRICT_MODE=false
EMAIL_DISABLE_SEND=true

# AI integration
AI_BASE_URL=https://bxntang-rtm-class-ai.hf.space
AI_CLIENT_ID=
AI_CLIENT_SECRET=
